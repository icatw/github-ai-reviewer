# Server
APP_ENV=production
HTTP_ADDR=:8088
PUBLIC_BASE_URL=https://reviewer.example.com

# GitHub App
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github-app-private-key.pem
# GITHUB_APP_PRIVATE_KEY is supported for local tests, but production should prefer a mounted file.
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=replace-with-webhook-secret

# LLM
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=replace-with-llm-api-key
LLM_MODEL=gpt-4o-mini

# Reporter outputs
# PR summary comments use the Issues API. Check Runs are advisory and non-blocking.

# Optional Go workspace checkout provider. Disabled by default.
GO_WORKSPACE_PROVIDER_ENABLED=false
GO_WORKSPACE_ROOT=/var/lib/github-ai-reviewer/workspaces
GO_WORKSPACE_CHECKOUT_TIMEOUT=30s
GO_WORKSPACE_OUTPUT_LIMIT_BYTES=16384

# Storage placeholder for later durable job state.
DATABASE_PATH=./data/reviewer.db
